{
  "[go]": {
    "editor.insertSpaces": false,
    "editor.tabSize": 4
  },
  "[python]": {
    "editor.tabSize": 4
  },
  "[ruby]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.insertSpaces": true,
    "editor.semanticHighlighting.enabled": true,
    "editor.tabSize": 2
  },
  "diffEditor.ignoreTrimWhitespace": true,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.cursorStyle": "line",
  "editor.fontFamily": "'Fira Code', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.formatOnSave": true,
  "editor.guides.bracketPairs": "active",
  "editor.inlineSuggest.enabled": true,
  "editor.minimap.enabled": false,
  "editor.rulers": [120],
  "editor.tabSize": 2,
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "editor.wordWrap": "off",
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },
  "gitlens.liveshare.allowGuestAccess": false,
  "redhat.telemetry.enabled": false,
  "svelte.enable-ts-plugin": true,
  "terminal.integrated.allowMnemonics": true,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.fontFamily": "'FiraMono Nerd Font Mono'",
  "terminal.integrated.scrollback": 5000,
  "vim.insertModeKeyBindings": [
    {
      "after": ["<Esc>"],
      "before": [";", ";"]
    }
  ],
  "vim.smartRelativeLine": true,
  "vim.useSystemClipboard": true,
  "window.newWindowDimensions": "maximized",
  "window.zoomLevel": -1,
  "workbench.colorTheme": "GitHub Light",
  "go.toolsManagement.autoUpdate": true,
  "java.maven.downloadSources": true,
  "maven.pomfile.autoUpdateEffectivePOM": true,
  "settingsSync.ignoredSettings": [
    "-java.configuration.runtimes",
    "-java.jdt.ls.java.home"
  ],
  "remote.autoForwardPortsSource": "hybrid",
  "gitlens.plusFeatures.enabled": false,
  "git.suggestSmartCommit": false,
  "[markdown]": {
    "diffEditor.ignoreTrimWhitespace": true
  },
  "go.lintTool": "golangci-lint",
  "githubPullRequests.pullBranch": "never",
  "github.copilot.advanced": {
    // "debug.overrideEngine": "chat-v2",
    // "debug.overrideProxyUrl": "http://127.0.0.1:8000",
    // "authProvider": "github-enterprise",
    "debug.codeQuote": true
  },
  "github.copilot.editor.enableAutoCompletions": true,
  // "github-enterprise.uri": "https://github.ghe.com"
}
